{
  "name": "maccabiaesthetica",
  "version": "1.0.0",
  "description": "Automation framework for web testing using Playwright Test + TypeScript",
  "scripts": {
    "test:prod": "npx playwright test --project=prod",
    "test:prod:debug": "npx playwright test --project=prod --debug",
    "test:prod:headed": "npx playwright test --project=prod --headed",

    "test:test": "npx playwright test --project=test",
    "test:test:headed": "npx playwright test --project=test --headed",

    "test:login:prod": "npx playwright test -g login_account --project=prod",
    "test:login:test": "npx playwright test -g login_account --project=test",
    "test:login:prod:headed": "npx playwright test -g login_account --project=prod --headed",
    "test:login:test:headed": "npx playwright test -g login_account --project=test --headed",
    "test:profile:prod:headed": "npx playwright test -g profile-page --project=prod --headed",

    "codegen": "npx playwright codegen https://maccabiaesthetica.co.il/",
    "report": "npx playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "typescript": "^5.8.0"
  }
}
